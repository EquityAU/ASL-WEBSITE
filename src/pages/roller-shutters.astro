              <path d="M12 2v20M2 5h20M7 3h10M2 9h20M17 3v4M7 3v4"></path>
              <path d="M8 13c0-1.1.9-2 2-2h4a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-5z"></path>
            </svg>
