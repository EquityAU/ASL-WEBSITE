---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

const pageTitle = 'Premium Roller Shutters Canberra | Australian Made | All Seasons Living';
const pageDescription = 'Insulated aluminium roller shutters in Canberra. Australian made & owned. Enhance security, control temperature, and block UV rays. Free measure & quote.';

// Product Schema for SEO
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Insulated Aluminium Roller Shutters',
  description: pageDescription,
  brand: {
    '@type': 'Brand',
    name: 'All Seasons Living'
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5.0',
    reviewCount: '47',
    bestRating: '5'
  },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'AUD',
    availability: 'https://schema.org/InStock',
    priceValidUntil: '2026-12-31'
  }
};

// Breadcrumb Schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://allseasonsliving.com.au/'
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Roller Shutters',
      item: 'https://allseasonsliving.com.au/roller-shutters'
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />

  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-image-container">
      <img
        src="/assets/images/roller-shutters/All Seasons Living -Roller Shutters.webp"
        alt="Premium insulated aluminium roller shutters installed on modern Canberra home providing security and temperature control"
        class="hero-image"
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <div class="container">
        <h1>Roller Shutters Canberra | Australian Made Security Shutters</h1>
        <p class="hero-subtitle">
          Enhance your home's security, comfort, and energy efficiency with premium Australian-made insulated aluminium roller shutters.
          Professionally installed in Canberra and surrounding regions.
        </p>
        <div class="hero-buttons">
          <a href="#quote-section" class="btn btn-primary">FREE MEASURE & QUOTE</a>
          <a href="tel:0261889606" class="btn btn-secondary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            (02) 6188 9606
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Three Key Benefits -->
  <section class="benefits-icons-section">
    <div class="container">
      <div class="benefits-grid-three">
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              <path d="M9 12l2 2 4-4"></path>
            </svg>
          </div>
          <h3>15 Year Warranty</h3>
          <p>Our Roller Shutters are backed by a full manufacturer's warranty, giving you peace of mind that your investment is protected with reliable quality and long-lasting performance.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
            </svg>
