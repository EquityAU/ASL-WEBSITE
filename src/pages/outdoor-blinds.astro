---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ExitIntentPopup from '../components/ExitIntentPopup.astro';

export const prerender = true;

// Product Schema for TruScreen Outdoor Blinds
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'TruScreen® Outdoor Blinds',
  image: 'https://allseasonsliving.com.au/assets/images/outdoor-blinds/Blinds Hero.webp',
  description: 'Australia\'s most advanced outdoor blind system with patented suspension technology. Eliminates gaps, prevents sagging, and delivers flawless performance.',
  brand: {
    '@type': 'Brand',
    name: 'TruScreen'
  },
  manufacturer: {
    '@type': 'Organization',
    name: 'All Seasons Living',
    url: 'https://allseasonsliving.com.au'
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '50000',
    bestRating: '5'
  },
  offers: {
    '@type': 'Offer',
    url: 'https://allseasonsliving.com.au/outdoor-blinds',
    priceCurrency: 'AUD',
    availability: 'https://schema.org/InStock',
    priceValidUntil: '2026-12-31',
    seller: {
      '@type': 'Organization',
      name: 'All Seasons Living'
    }
  },
  additionalProperty: [
    {
      '@type': 'PropertyValue',
      name: 'Warranty',
      value: '10 Year Product Warranty'
    },
    {
      '@type': 'PropertyValue',
      name: 'Country of Origin',
      value: 'Australia'
    },
    {
      '@type': 'PropertyValue',
      name: 'Material',
      value: 'PVC Coated Fiberglass, Aluminium 6063'
    }
  ]
};

// Breadcrumb Schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://allseasonsliving.com.au'
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Outdoor Blinds',
      item: 'https://allseasonsliving.com.au/outdoor-blinds'
    }
  ]
};
---

<Layout
  title="Outdoor Blinds Canberra | TruScreen® & Straight Drop | Australian Made"
  description="Premium outdoor blinds for Canberra homes. Choose TruScreen® gap-free zip blinds or affordable Straight Drop blinds. Australian made, 10-year warranty. Free measure & quote."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="hero-image-container">
        <img
          src="/assets/images/outdoor-blinds/Blinds Hero.webp"
          alt="Premium outdoor blinds installed on Canberra patio - Australian made TruScreen and Straight Drop systems"
          width="1920"
          height="1080"
          loading="eager"
          fetchpriority="high"
        />
        <div class="hero-overlay"></div>
      </div>
      <div class="hero-content">
        <div class="container">
          <h1>Outdoor Blinds Canberra</h1>
          <p class="hero-subtitle">Transform your outdoor space with Australian-made blinds engineered for performance, privacy, and year-round comfort. Two systems, one goal — the perfect fit for your home.</p>
          <div class="hero-stats">
            <div class="stat">
              <strong>50,000+</strong>
              <span>Happy Customers</span>
            </div>
            <div class="stat">
              <strong>10-Year</strong>
              <span>Product Warranty</span>
            </div>
            <div class="stat">
              <strong>Local</strong>
              <span>Owned & Manufactured</span>
            </div>
          </div>
          <div class="hero-buttons">
            <a href="#product-selector" class="btn btn-primary">Explore Our Range</a>
            <a href="#quote-section" class="btn btn-outline-hero">Free Measure & Quote</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Product Selector Section -->
    <section id="product-selector" class="product-selector-section">
      <div class="container">
        <div class="selector-header">
          <h2>Find the right blind for your space</h2>
          <p>We offer two outdoor blind systems to suit every home, budget, and lifestyle. Choose a product below to explore its features.</p>
        </div>

        <div class="product-toggle-cards">
          <button class="toggle-card active" data-product="truscreen" aria-pressed="true">
            <span class="toggle-badge">Most Popular</span>
            <div class="toggle-card-image">
              <img src="/assets/images/outdoor-blinds/TruScreen Track Blinds.webp" alt="TruScreen zip track blinds installed on home" loading="lazy" />
            </div>
            <div class="toggle-card-content">
              <h3>TruScreen<span class="trademark">®</span> Track Blinds</h3>
              <p class="toggle-tagline">Premium gap-free zip system</p>
              <ul class="toggle-highlights">
                <li>Patented Track Technology</li>
                <li>Eliminates gaps and sagging</li>
                <li>Motorisation-ready</li>
              </ul>
              <span class="toggle-spec">Zero gaps. Zero sagging.</span>
            </div>
            <div class="toggle-indicator">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </div>
          </button>

          <div class="toggle-divider">
            <span>or</span>
          </div>

          <button class="toggle-card" data-product="straightdrop" aria-pressed="false">
            <span class="toggle-badge value">Great Value</span>
            <div class="toggle-card-image">
              <img src="/assets/images/outdoor-blinds/Straight Drop Blinds.webp" alt="Straight drop outdoor blinds installed on patio" loading="lazy" />
            </div>
            <div class="toggle-card-content">
              <h3>Straight Drop Blinds</h3>
              <p class="toggle-tagline">Simple, versatile, affordable</p>
              <ul class="toggle-highlights">
                <li>No posts or tracks required</li>
                <li>Quick, simple installation</li>
                <li>Manual or motorised</li>
              </ul>
              <span class="toggle-spec">Simple by design.</span>
            </div>
            <div class="toggle-indicator">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </div>
          </button>
        </div>
      </div>
    </section>

    <!-- Quick Comparison Table -->
    <section class="comparison-section">
      <div class="container">
        <h2>At a Glance</h2>
        <p class="comparison-subtitle">See how our two systems compare across the features that matter most.</p>
        <div class="comparison-table-wrapper">
          <table class="comparison-table">
            <thead>
              <tr>
                <th>Feature</th>
                <th class="col-truscreen">
                  <span class="table-product-name">TruScreen<span class="trademark">®</span></span>
                  <span class="table-product-tag">Premium</span>
                </th>
                <th class="col-straightdrop">
                  <span class="table-product-name">Straight Drop</span>
                  <span class="table-product-tag value">Value</span>
                </th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Side retention</td>
                <td class="col-truscreen">Adaptive zip channels</td>
                <td class="col-straightdrop">None required</td>
              </tr>
              <tr>
                <td>Gap protection</td>
                <td class="col-truscreen">Gap-free seal</td>
                <td class="col-straightdrop">Open sides</td>
              </tr>
              <tr>
                <td>Wind resistance</td>
                <td class="col-truscreen">Shock-absorption system</td>
                <td class="col-straightdrop">Base anchor clip</td>
              </tr>
              <tr>
                <td>Operation</td>
                <td class="col-truscreen">Remote / Manual</td>
                <td class="col-straightdrop">Manual</td>
              </tr>
              <tr>
                <td>Price point</td>
                <td class="col-truscreen">Premium</td>
                <td class="col-straightdrop">More affordable</td>
              </tr>
              <tr>
                <td>Best for</td>
                <td class="col-truscreen">Full weather protection</td>
                <td class="col-straightdrop">Shade, privacy & tight spaces</td>
              </tr>
              <tr>
                <td>Warranty</td>
                <td class="col-truscreen">10 years</td>
                <td class="col-straightdrop">10 years</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="comparison-cta">
          <p>Not sure which system is right for you?</p>
          <a href="#quote-section" class="btn btn-primary">Get Expert Advice — Free Quote</a>
        </div>
      </div>
    </section>

    <!-- TRUSCREEN DETAIL SECTION -->
    <section id="truscreen-features" class="product-detail-section">
      <div class="container">
        <div class="detail-header">
          <span class="detail-label">Premium System</span>
          <h2>TruScreen<span class="trademark">®</span> Track Blinds</h2>
          <p>Australia's most advanced outdoor blind system — engineered to eliminate gaps, prevent sagging, and deliver flawless performance in any weather.</p>
        </div>

        <!-- Gap-Free Intro -->
        <div class="detail-intro-block">
          <h3>The gap-free difference</h3>
          <p>Most patios aren't perfectly square. Traditional outdoor blinds leave visible gaps that installers patch with foam strips — a compromise that looks unprofessional and fails over time.</p>
          <p><strong>TruScreen's patented suspension system adapts to your structure</strong>, creating a seamless, professional fit without workarounds. It's proper engineering, not a quick fix.</p>
        </div>

        <!-- Feature: Adaptive Side Channels -->
        <div class="detail-feature">
          <div class="detail-feature-image">
            <img src="/assets/images/outdoor-blinds/Duel Channel Render.webp" alt="TruScreen dual channel adaptive side channel system - gap-free outdoor blinds with adjustable installation technology" loading="lazy" />
          </div>
          <div class="detail-feature-text">
            <h3>Adaptive side channels</h3>
            <p>Our flexible guide system automatically compensates for structures that aren't level or square. The channels adjust during installation to create tight, professional edges — no foam fillers, no gaps, no compromises.</p>
            <ul class="detail-benefits">
              <li>Accommodates structural irregularities</li>
              <li>Maintains constant fabric tension</li>
              <li>Eliminates unsightly gap fillers</li>
            </ul>
          </div>
        </div>

        <!-- Feature: Impact-Resistant Suspension -->
        <div class="detail-feature reverse">
          <div class="detail-feature-image">
            <img src="/assets/images/outdoor-blinds/truscreen render.webp" alt="TruScreen patented shock-absorption suspension system - wind resistant impact protection" loading="lazy" />
          </div>
          <div class="detail-feature-text">
            <h3>Impact-resistant suspension</h3>
            <p>Wind gusts and accidental bumps don't damage TruScreen blinds. Our integrated shock-absorption system allows the fabric to flex under pressure, then automatically return to position.</p>
            <ul class="detail-benefits">
              <li>Flexes with wind and impacts</li>
              <li>Self-recovering fabric system</li>
              <li>Protects your investment from damage</li>
            </ul>
          </div>
        </div>

        <!-- Technical Breakdown -->
        <div class="technical-block">
          <h3>A Truly Unique Blind System</h3>
          <div class="technical-layout">
            <div class="technical-image">
              <img src="/assets/images/outdoor-blinds/Full Blind Render.png" alt="TruScreen complete outdoor blind system - motorised zip blinds with headbox channels and suspension technology" loading="lazy" />
            </div>
            <div class="technical-content">
              <div class="tech-item">
                <h4>Performance Under Pressure</h4>
                <p>The specially designed bottom bar minimizes movement even at wide widths, while the split bottom bar caps secure the zip more effectively for reliable performance.</p>
              </div>
              <div class="tech-item">
                <h4>Self Adjusting Track</h4>
                <p>The two separate channels allow for adjustable installation in any environment, accommodating structures that aren't perfectly level or square.</p>
              </div>
              <div class="tech-item">
                <h4>Suspension System</h4>
                <p>Optimized fabric polymer channels and tension polymer ensure optimal fabric tensions, providing the best solution for maintaining fabric stability at all times.</p>
              </div>
              <div class="tech-item">
                <h4>Rubber Ring</h4>
                <p>Reduces vibration from the motor and noise from the headbox, allowing for quiet operation and enhanced performance throughout the system's lifespan.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Feature Videos -->
        <div class="videos-block">
          <h3>See TruScreen Innovation in Action</h3>
          <div class="videos-grid">
            <div class="video-item">
              <div class="video-wrapper">
                <video autoplay loop muted playsinline>
                  <source src="/assets/images/outdoor-blinds/SHOCK-ABSORPTION.mp4" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
              </div>
              <h4>Exclusive Shock Absorption System</h4>
              <p>Watch how TruScreen's patented suspension flexes with impacts and automatically returns to position, protecting your investment from wind and accidental bumps.</p>
            </div>
            <div class="video-item">
              <div class="video-wrapper">
                <video autoplay loop muted playsinline>
                  <source src="/assets/images/outdoor-blinds/BOTTOM-BAR-DESIGN-v2.mp4" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
              </div>
              <h4>Unique Bottom Bar Design</h4>
              <p>See the specially engineered bottom bar that minimizes movement across wide spans while split caps secure the zip more effectively than any other system.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Australian Made (Shared) -->
    <section class="australian-made-section">
      <div class="container">
        <div class="australian-content">
          <img src="/assets/images/outdoor-blinds/Australian Made.png" alt="Australian Made certified outdoor blinds Canberra - locally manufactured with 10 year warranty" class="australian-icon" />
          <h2>Proudly Australian Made & Owned</h2>
          <p>Both our TruScreen and Straight Drop systems are designed, engineered, and manufactured right here in Australia by a family-owned business. Built with motorisation in mind from day one, our blinds deliver whisper-quiet operation with seamless smart home integration. Supporting local jobs while setting the global standard for outdoor blind innovation.</p>
        </div>
      </div>
    </section>

    <!-- STRAIGHT DROP DETAIL SECTION -->
    <section id="straight-drop-features" class="product-detail-section sd-section">
      <div class="container">
        <div class="detail-header">
          <span class="detail-label value">Great Value</span>
          <h2>Straight Drop Outdoor Blinds</h2>
          <p>Sleek, unobtrusive, and elegant — shade and privacy without the need for tracks. The smart choice when you want outdoor comfort without the complexity.</p>
        </div>

        <!-- Hero Image + Description -->
        <div class="detail-feature">
          <div class="detail-feature-image">
            <img src="/assets/images/outdoor-blinds/Straight Drop Blinds.webp" alt="Straight drop outdoor blinds installed on Australian home patio" loading="lazy" />
          </div>
          <div class="detail-feature-text">
            <h3>No posts — No worries</h3>
            <p>Straight Drop outdoor blinds provide a clean, minimal finish — ideal for areas without posts or where side retention isn't needed. Unlike track-guided or wire-guided systems, they don't use side channels or wires, making them simpler to install and well-suited to narrow spaces, patios, or balconies where other systems don't fit neatly.</p>
            <p><strong>Designed for versatility and to fit any space</strong>, offering protection from the weather as well as added privacy for your backyard. Our range of outdoor blinds are custom designed to complement your home.</p>
          </div>
        </div>

        <!-- Benefits Grid -->
        <div class="sd-benefits-block">
          <h3>Why simple works better outdoors</h3>
          <div class="sd-benefits-grid">
            <div class="sd-benefit-card">
              <div class="sd-benefit-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
              <h4>No side tracks or wires</h4>
              <p>No channels, zips, or cables needed — ideal for areas where structural fixings aren't possible.</p>
            </div>
            <div class="sd-benefit-card">
              <div class="sd-benefit-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              </div>
              <h4>Faster installation</h4>
              <p>Fewer components mean quicker installation, saving time and reducing labour costs.</p>
            </div>
            <div class="sd-benefit-card">
              <div class="sd-benefit-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
              </div>
              <h4>More affordable</h4>
              <p>Simpler design and fewer moving parts make them more cost-effective than track-guided systems.</p>
            </div>
            <div class="sd-benefit-card">
              <div class="sd-benefit-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line></svg>
              </div>
              <h4>Fits narrow or awkward spaces</h4>
              <p>Perfect for balconies, tight spaces, or areas with uneven walls where track systems can't be used.</p>
            </div>
            <div class="sd-benefit-card">
              <div class="sd-benefit-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
              </div>
              <h4>Minimal visual impact</h4>
              <p>Clean, minimal look preserves open views and blends into modern and traditional home styles.</p>
            </div>
            <div class="sd-benefit-card">
              <div class="sd-benefit-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
              </div>
              <h4>Built to last</h4>
              <p>High quality components and workmanship engineered to withstand harsh Australian conditions.</p>
            </div>
          </div>
        </div>

        <!-- Operation Options -->
        <div class="sd-operation-block">
          <h3>Simple, versatile operation</h3>
          <p class="sd-operation-intro">Straight Drop blinds offer a range of control options — manual or motorised — to suit different spaces, budgets, and convenience needs.</p>
          <div class="sd-operation-grid">
            <div class="sd-operation-card">
              <div class="sd-operation-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
              </div>
              <h4>Crank handle</h4>
              <p>Easy to use, no electricity required. Ideal for areas without power access or where precise manual control is preferred.</p>
            </div>
            <div class="sd-operation-card">
              <div class="sd-operation-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
              </div>
              <h4>Motorised control</h4>
              <p>One-touch operation via remote, wall switch, or app. Great for multiple blinds or hard-to-reach installations.</p>
            </div>
            <div class="sd-operation-card">
              <div class="sd-operation-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
              </div>
              <h4>Smart home</h4>
              <p>Sync with home automation for timers, sensors, or voice control — better energy efficiency and comfort.</p>
            </div>
          </div>
        </div>

        <!-- Specs bar -->
        <div class="sd-specs-bar">
          <div class="sd-spec">
            <strong>Up to 6 metres wide</strong>
            <span>with a 3 metre drop</span>
          </div>
          <div class="sd-spec">
            <strong>Base anchor clip</strong>
            <span>for secure positioning</span>
          </div>
          <div class="sd-spec">
            <strong>Custom-made</strong>
            <span>to fit any size and shape</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Frame & Headbox Colours (Shared) -->
    <section class="colours-section">
      <div class="container">
        <h2>Frame & Headbox Colours</h2>
        <p class="colours-intro">All headboxes and guides are high grade aluminium. Choose from 6 standard colours. All Scratch Resistant Dulux Powdercoated Aluminium 6063 Closed Headbox & Guides.</p>
        <div class="colour-grid">
          <div class="colour"><div class="swatch" style="background: #000;"></div><span>Black</span></div>
          <div class="colour"><div class="swatch" style="background: #FFF;"></div><span>Snow White</span></div>
          <div class="colour"><div class="swatch" style="background: #F2EBDC;"></div><span>Classic Cream</span></div>
          <div class="colour"><div class="swatch" style="background: #8E8174;"></div><span>Paperbark</span></div>
          <div class="colour"><div class="swatch" style="background: #353535;"></div><span>Monument</span></div>
          <div class="colour"><div class="swatch" style="background: #4A4D49;"></div><span>Woodland Grey</span></div>
        </div>

        <h2>Premium ViewShade Fabric Technology</h2>
        <p class="fabric-intro">Choose from two advanced PVC-coated fiberglass fabrics — both backed by a 10-year warranty and Australian Standards certified for fire resistance.</p>

        <div class="fabric-showcase">
          <div class="fabric-options-grid">
            <div class="fabric-card">
              <div class="fabric-header">
                <h3>ViewShade DS95</h3>
                <span class="openness-badge openness-5">5% Openness Factor</span>
              </div>
              <p class="fabric-type">PVC Coated Fiberglass &bull; 2x2 Weave</p>
              <div class="fabric-benefits">
                <div class="benefit-item">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                  <span>95% solar heat reduction</span>
                </div>
                <div class="benefit-item">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                  <span>Superior dimensional stability</span>
                </div>
                <div class="benefit-item">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                  <span>Best for wide spans (minimal movement)</span>
                </div>
                <div class="benefit-item">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                  <span>Exceptional weather protection</span>
                </div>
              </div>
              <div class="fabric-tech-specs">
                <span class="spec">560 GSM</span>
                <span class="spec-divider">&bull;</span>
                <span class="spec">Up to 305cm width</span>
                <span class="spec-divider">&bull;</span>
                <span class="spec">AS 1530.2 & 3</span>
              </div>
            </div>

            <div class="fabric-card">
              <div class="fabric-header">
                <h3>ViewShade DS99</h3>
