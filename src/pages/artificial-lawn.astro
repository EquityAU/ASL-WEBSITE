<script>
  import { captureFormData, initializeSessionTracking, storePendingEnhancedConversion } from '../utils/formTracking';

  initializeSessionTracking();

  const form = document.getElementById('artificialLawnQuoteForm') as HTMLFormElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = document.getElementById('alQuoteSubmitBtn') as HTMLButtonElement;

      const name = (document.getElementById('al-name') as HTMLInputElement)?.value.trim();
      const phone = (document.getElementById('al-phone') as HTMLInputElement)?.value.trim();
      const suburb = (document.getElementById('al-suburb') as HTMLInputElement)?.value.trim();

      if (!name || !phone || !suburb) {
        alert('Please fill in all required fields');
        return;
      }

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.classList.add('loading');
      }

      try {
        const formData = new FormData(form);
        const leadData = {
          name: formData.get('name') as string,
          email: formData.get('email') as string,
          phone: formData.get('phone') as string,
          suburb: formData.get('suburb') as string,
          product: 'Artificial Lawn',
          message: formData.get('message') as string || undefined,
        };

        const submission = captureFormData(leadData, 'artificialLawnQuoteForm', 'artificial-lawn-inline-form');

        const response = await fetch('/api/submit-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(submission),
        });

        const result = await response.json();

        if (response.ok && result.success) {
          storePendingEnhancedConversion(leadData);
          window.location.href = '/thank-you';
        } else {
          throw new Error(result.message || 'Submission failed');
        }
      } catch (error) {
        console.error('Form error:', error);
        alert('There was an error submitting your form. Please try calling us directly at (02) 6188 9606.');

        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.classList.remove('loading');
        }
      }
    });
  }
</script>

