---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

const pageTitle = 'Artificial Lawn Canberra | Premium Synthetic Grass | All Seasons Living';
const pageDescription = 'Premium artificial lawn installation in Canberra. Synthetic grass designed for the Australian climate. Pet-friendly, low maintenance, and looks great all year. Free measure & quote.';

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Premium Artificial Lawn',
  description: pageDescription,
  brand: {
    '@type': 'Brand',
    name: 'All Seasons Living'
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5.0',
    reviewCount: '47',
    bestRating: '5'
  },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'AUD',
    availability: 'https://schema.org/InStock',
    priceValidUntil: '2026-12-31'
  }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://allseasonsliving.com.au/'
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Artificial Lawn',
      item: 'https://allseasonsliving.com.au/artificial-lawn'
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />

  <!-- ======================== HERO ======================== -->
  <section class="hero">
    <div class="hero-bg">
      <img
        src="/assets/images/artificial-lawn/asl-artificial-lawn-hero.webp"
        alt="Premium artificial lawn installation in Canberra showing lush synthetic grass in modern backyard"
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-content">
        <h1>Premium Artificial Lawn in Canberra</h1>
        <p class="hero-sub">Transform your outdoor space with synthetic grass designed for Australian conditions. Lush, green, and maintenance-free all year round — perfect for families, pets, and busy lifestyles.</p>
        <div class="hero-ctas">
          <a href="#quote-section" class="btn btn-primary btn-lg">Get Free Measure & Quote</a>
          <a href="tel:0261889606" class="btn btn-outline-light">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            (02) 6188 9606
          </a>
        </div>
        <a href="https://tigerturf.com/au/" target="_blank" rel="noopener noreferrer" class="hero-badge">
          <span class="badge-text">Authorized TigerTurf Provider</span>
          <img src="/assets/images/artificial-lawn/tigerturf-logo-green.svg" alt="TigerTurf" class="badge-logo" />
        </a>
      </div>
    </div>
  </section>

  <!-- ======================== KEY BENEFITS ======================== -->
