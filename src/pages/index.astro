<script>
  import { captureFormData, initializeSessionTracking, storePendingEnhancedConversion } from '../utils/formTracking';

  // Initialize session tracking on page load
  initializeSessionTracking();

  // Form submission handler with comprehensive tracking
  const quoteForm = document.getElementById('mainQuoteForm');
  if (quoteForm) {
    quoteForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      console.log('[mainQuoteForm] Form submission started');

      // Disable submit button to prevent double submission
      const submitBtn = document.getElementById('mainQuoteSubmitBtn') as HTMLButtonElement;
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.classList.add('loading');
      }

      try {
        // Get form data
        const formData = new FormData(quoteForm);
        const leadData = {
          name: formData.get('name') as string,
          email: formData.get('email') as string,
          phone: formData.get('phone') as string,
          suburb: formData.get('suburb') as string,
          product: formData.get('product') as string,
          bestTime: formData.get('best-time') as string || undefined,
          message: formData.get('message') as string || undefined,
        };

        // Capture comprehensive tracking data
        const submission = captureFormData(leadData, 'mainQuoteForm', 'homepage-quote-form');

        console.log('Full Lead Submission Data:', submission);

        // Send to API endpoint
        const response = await fetch('/api/submit-lead', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(submission),
        });

        const result = await response.json();
        console.log('[mainQuoteForm] API response:', response.status, result);

        if (response.ok && result.success) {
          console.log('[mainQuoteForm] API call successful');
          // Conversion tracking happens on thank-you page (no race condition)
          storePendingEnhancedConversion(leadData);
          console.log('[mainQuoteForm] Redirecting to thank-you page...');
          window.location.href = '/thank-you';
        } else {
          throw new Error(result.message || 'Submission failed');
        }
      } catch (error) {
        console.error('Form submission error:', error);
        alert('There was an error submitting your form. Please try calling us directly at (02) 6188 9606.');

        // Re-enable submit button
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.classList.remove('loading');
        }
      }
    });
  }

  // Product card "Get Quote" buttons - scroll to form and pre-select product
  const productQuoteBtns = document.querySelectorAll('.product-quote-btn');
  productQuoteBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const product = btn.getAttribute('data-product');
      const productSelect = document.getElementById('product') as HTMLSelectElement;
      if (productSelect && product) {
        productSelect.value = product;
      }
      const formSection = document.getElementById('quote-section');
      if (formSection) {
        formSection.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>
