---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ReviewsCarousel from '../components/ReviewsCarousel.astro';
import { Image } from 'astro:assets';
import heroImage from '../../public/assets/images/roller-shutters/ASL Shutters.webp';
import outdoorBlindsImage from '../../public/assets/images/outdoor-blinds/Outdoor Motorised Blinds.webp';
import rollerShuttersImage from '../../public/assets/images/roller-shutters/All Seasons Living -Roller Shutters.webp';
import artificialLawnImage from '../../public/assets/images/artificial-lawn/Artificial-lawn-asl-media.webp';

export const prerender = true;
---

<Layout title="Outdoor Blinds, Roller Shutters & Artificial Lawn Canberra" description="Canberra's trusted home improvement specialists. Premium outdoor blinds, roller shutters, and artificial lawn — Australian made with expert installation. Free measure & quote.">
  <Fragment slot="head">
    <link rel="preload" as="image" href={heroImage.src} fetchpriority="high" />
  </Fragment>

  <Header />

  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg">
        <Image
          src={heroImage}
          alt="Australian home fitted with roller shutters by All Seasons Living, Canberra"
          width={1920}
          height={1920}
          loading="eager"
          fetchpriority="high"
        />
        <div class="hero-overlay"></div>
      </div>
      <div class="container hero-inner">
        <div class="hero-content">
          <h1>Premium Outdoor Living Solutions in Canberra</h1>
          <p class="hero-sub">Outdoor Blinds, Roller Shutters & Artificial Lawn — Australian made, expertly installed, backed by up to 15 years warranty.</p>
          <div class="hero-ctas">
            <a href="#quote-section" class="btn btn-primary btn-lg">Get Free Measure & Quote</a>
            <a href="tel:0261889606" class="btn btn-outline-light">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
              (02) 6188 9606
            </a>
          </div>
        </div>
        <div class="hero-stats">
          <div class="stat-item">
            <strong>5-Star</strong>
            <span>Customer Experience</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <strong>Premium</strong>
            <span>Materials</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <strong>Built for</strong>
            <span>Australian Conditions</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <strong>Seamless</strong>
            <span>End-to-End Service</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Bar -->
    <section class="trust-bar">
      <div class="container">
        <div class="trust-items">
          <div class="trust-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Fully Licensed & Insured</span>
          </div>
          <div class="trust-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
            <span>Industry Leading Warranties</span>
          </div>
          <div class="trust-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span>Local Canberra Business</span>
          </div>
          <div class="trust-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            <span>Fast & Efficient Service</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Product Showcase -->
    <section class="products-section">
      <div class="container">
        <div class="section-header">
          <h2>Our Products</h2>
          <p>Premium solutions designed and tested for Australian conditions — from durability to style.</p>
        </div>
        <div class="product-cards">
          <!-- Outdoor Blinds -->
          <div class="product-card featured">
            <span class="product-badge">Most Popular</span>
            <div class="product-card-image">
              <Image src={outdoorBlindsImage} alt="TruScreen motorised outdoor blinds installed on Canberra patio" width={600} height={400} loading="lazy" />
            </div>
            <div class="product-card-body">
              <h3>Outdoor Blinds</h3>
              <p>TruScreen® track blinds and Straight Drop systems — gap-free, wind-rated, and smart-home ready.</p>
              <ul class="product-features">
                <li>Patented suspension technology</li>
                <li>Motorised with app control</li>
                <li>10-year product warranty</li>
              </ul>
              <div class="product-card-actions">
                <a href="/outdoor-blinds" class="btn btn-outline" aria-label="Learn more about Outdoor Blinds">Learn More</a>
                <button class="btn btn-primary product-quote-btn" data-product="Outdoor Blinds">Get Quote</button>
              </div>
            </div>
          </div>

          <!-- Roller Shutters -->
          <div class="product-card">
            <div class="product-card-image">
              <Image src={rollerShuttersImage} alt="Premium roller shutters on Canberra home for security and insulation" width={600} height={400} loading="lazy" />
            </div>
            <div class="product-card-body">
              <h3>Roller Shutters</h3>
              <p>Security, insulation, and noise reduction in one system — the complete window protection solution.</p>
              <ul class="product-features">
                <li>Full light blockout capability</li>
                <li>Enhanced home security</li>
                <li>Up to 90% noise reduction</li>
              </ul>
              <div class="product-card-actions">
                <a href="/roller-shutters" class="btn btn-outline" aria-label="Learn more about Roller Shutters">Learn More</a>
                <button class="btn btn-primary product-quote-btn" data-product="Roller Shutters">Get Quote</button>
              </div>
            </div>
          </div>

          <!-- Artificial Lawn -->
          <div class="product-card">
            <div class="product-card-image">
              <Image src={artificialLawnImage} alt="Pet-friendly artificial lawn installation in Canberra backyard" width={600} height={400} loading="lazy" />
            </div>
            <div class="product-card-body">
              <h3>Artificial Lawn</h3>
              <p>Premium artificial grass that looks and feels real — no mowing, no watering, green all year round.</p>
              <ul class="product-features">
                <li>Pet & child friendly</li>
                <li>Save thousands on water bills</li>
                <li>10-year UV warranty</li>
              </ul>
              <div class="product-card-actions">
                <a href="/artificial-lawn" class="btn btn-outline" aria-label="Learn more about Artificial Lawn">Learn More</a>
                <button class="btn btn-primary product-quote-btn" data-product="Artificial Lawn">Get Quote</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="how-it-works">
      <div class="container">
        <div class="section-header">
          <h2>How It Works</h2>
          <p>From first call to finished result — our process is simple, transparent, and stress-free.</p>
        </div>
        <div class="steps-row">
          <div class="step">
            <div class="step-number">1</div>
            <div class="step-connector"></div>
            <h3>Free Consultation</h3>
            <p>We visit your home, take measurements, and discuss the best options for your space and budget.</p>
          </div>
          <div class="step">
            <div class="step-number">2</div>
            <div class="step-connector"></div>
            <h3>Custom Design & Quote</h3>
            <p>You receive a detailed, no-obligation quote with product recommendations tailored to your needs.</p>
          </div>
          <div class="step">
            <div class="step-number">3</div>
            <h3>Expert Installation</h3>
            <p>Our licensed installers complete the job with precision — backed by a 24-month workmanship guarantee.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Customer Reviews -->
    <ReviewsCarousel />

    <!-- Quote Form Section -->
    <section id="quote-section" class="quote-section">
      <svg class="quote-blob quote-blob-left" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <path fill="rgba(255, 255, 255, 0.1)" d="M44.7,-76.4C58.8,-69.2,71.8,-59.1,79.6,-45.8C87.4,-32.6,90,-16.3,88.5,-0.9C87,14.6,81.4,29.2,73.1,42.2C64.8,55.2,53.8,66.6,40.3,73.8C26.8,81,10.8,84,-5.3,83.3C-21.4,82.6,-42.8,78.2,-58.4,68.2C-74,58.2,-83.8,42.6,-88.5,25.4C-93.2,8.2,-92.8,-10.6,-86.6,-26.8C-80.4,-43,-68.4,-56.6,-54.1,-64.2C-39.8,-71.8,-23.2,-73.4,-7.5,-75.9C8.2,-78.4,30.6,-83.6,44.7,-76.4Z" transform="translate(100 100)" />
      </svg>
      <svg class="quote-blob quote-blob-right" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <path fill="rgba(255, 255, 255, 0.1)" d="M39.5,-67.3C51.4,-60.1,61.5,-50.3,68.4,-38.5C75.3,-26.7,79,-13,79.8,1.1C80.6,15.2,78.5,30.4,71.4,43.2C64.3,56,52.2,66.4,38.6,72.7C25,79,9.9,81.2,-5.4,80.6C-20.7,80,-41.4,76.6,-56.8,67.8C-72.2,59,-82.3,44.8,-86.4,29C-90.5,13.2,-88.6,-4.2,-82.8,-19.4C-77,-34.6,-67.3,-47.6,-55.1,-54.7C-42.9,-61.8,-28.2,-63,-14.3,-64.7C-0.4,-66.4,12.7,-68.6,24.7,-67.3C36.7,-66,47.6,-61.2,39.5,-67.3Z" transform="translate(100 100)" />
      </svg>
      <div class="container">
        <div class="quote-layout">
          <div class="quote-persuasion">
            <h2>Get a Free Design & Quote</h2>
            <p>One of our specialists will visit your home, measure your space, and design the perfect solution — completely free, no obligation.</p>
            <div class="quote-benefits">
              <div class="qb">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <span>Response within 24 hours</span>
              </div>
              <div class="qb">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <span>No pressure, no obligation</span>
              </div>
              <div class="qb">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <span>Expert product guidance</span>
              </div>
              <div class="qb">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <span>Transparent, itemised pricing</span>
              </div>
            </div>
          </div>
          <div class="quote-form-wrapper">
            <form class="quote-form" id="mainQuoteForm">
              <div class="form-grid">
                <input type="text" id="name" name="name" placeholder="Name*" required autocomplete="name" />
                <input type="tel" id="phone" name="phone" placeholder="Phone*" required autocomplete="tel" />
                <input type="email" id="email" name="email" placeholder="Email*" required autocomplete="email" />
                <input type="text" id="suburb" name="suburb" placeholder="Suburb*" required autocomplete="address-level2" />
                <label for="product" class="sr-only">Product Interest</label>
                <select id="product" name="product" required aria-label="Product Interest">
                  <option value="">Select Product*</option>
                  <option value="Outdoor Blinds">Outdoor Blinds</option>
                  <option value="Roller Shutters">Roller Shutters</option>
                  <option value="Artificial Lawn">Artificial Lawn</option>
                </select>
                <label for="best-time" class="sr-only">Best Time to Call</label>
                <select id="best-time" name="best-time" aria-label="Best Time to Call">
                  <option value="">Best Time to Call</option>
                  <option value="morning">Morning (8am-12pm)</option>
                  <option value="afternoon">Afternoon (12pm-5pm)</option>
                  <option value="evening">Evening (5pm-8pm)</option>
                  <option value="anytime">Anytime</option>
                </select>
                <textarea id="message" name="message" rows="3" placeholder="Tell us about your project..."></textarea>
                <button type="submit" class="btn btn-primary" id="mainQuoteSubmitBtn">
                  <span class="submit-text">GET MY FREE QUOTE NOW</span>
                  <span class="submit-loading" style="display: none;">
                    <svg class="spinner" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/>
                      <path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
                    </svg>
                    Submitting...
                  </span>
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="why-choose">
      <div class="container">
        <div class="section-header">
          <h2>Why Canberra Homeowners Choose Us</h2>
        </div>
        <div class="reasons-grid">
          <div class="reason">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <div>
              <strong>Locally Owned & Operated</strong>
              <p>We're a Canberra family business — not a franchise. You deal directly with the owners.</p>
            </div>
          </div>
          <div class="reason">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <div>
              <strong>Licensed & Trained Installers</strong>
              <p>Every installation is completed by qualified professionals — never subcontracted out.</p>
            </div>
          </div>
          <div class="reason">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
            <div>
              <strong>100% Australian Made Products</strong>
              <p>Our products are designed and manufactured in Australia — supporting local jobs and quality.</p>
            </div>
          </div>
          <div class="reason">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <div>
              <strong>Up to 15-Year Warranties</strong>
              <p>Industry-leading product warranties so you can buy with confidence.</p>
            </div>
          </div>
          <div class="reason">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <div>
              <strong>Personalised Service</strong>
              <p>From first consultation to final walkthrough — one dedicated specialist handles your project.</p>
            </div>
          </div>
          <div class="reason">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
            <div>
              <strong>Transparent Pricing</strong>
              <p>Itemised quotes with no hidden costs. The price we quote is the price you pay.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta">
      <div class="container">
        <h2>Ready to transform your home?</h2>
        <p>Your home deserves better than off-the-shelf.</p>
        <div class="final-cta-actions">
          <a href="#quote-section" class="btn btn-primary btn-lg">Get Your Free Quote</a>
          <a href="tel:0261889606" class="btn btn-outline-dark">Call (02) 6188 9606</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ============================
     HERO
     ============================ */
  .hero {
    position: relative;
    height: 100vh;
    height: 100dvh;
    min-height: 580px;
    display: flex;
    align-items: center;
    color: var(--white);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 1;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 55%;
  }

  .hero-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.3) 0%,
      rgba(0,0,0,0.35) 30%,
      rgba(0,0,0,0.45) 50%,
      rgba(0,0,0,0.5) 70%,
      rgba(0,0,0,0.7) 100%
    );
    z-index: 2;
  }

  .hero-inner {
    position: relative;
    z-index: 3;
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
  }

  .hero h1 {
    font-size: clamp(1.75rem, 7vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
    max-width: 700px;
  }

  .hero-sub {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.65;
    max-width: 620px;
    opacity: 0.95;
    margin-bottom: 0.5rem;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
  }

  .btn-outline-light {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    color: var(--white);
    border: 2px solid rgba(255,255,255,0.5);
    padding: 1rem 1.75rem;
    font-weight: 700;
    border-radius: 8px;
    text-decoration: none;
    font-size: 1rem;
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .btn-outline-light:hover {
    background: rgba(255,255,255,0.12);
    border-color: var(--white);
    color: var(--white);
    transform: translateY(-2px);
  }

  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 1.25rem 0;
    border-top: none;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
  }

  .stat-item strong {
    font-size: 1.125rem;
    font-weight: 700;
  }

  .stat-item span {
    font-size: 0.8125rem;
    opacity: 0.85;
  }

  .stat-divider {
    width: 1px;
    background: rgba(255,255,255,0.25);
    display: none;
  }

  /* ============================
     TRUST BAR
     ============================ */
  .trust-bar {
    background: var(--olive-green);
    padding: 1rem 0;
    position: relative;
    z-index: 0;
  }

  .trust-items {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--white);
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .trust-item svg {
    flex-shrink: 0;
    opacity: 0.9;
  }

  /* ============================
     PRODUCT SHOWCASE
     ============================ */
  .products-section {
    padding: 4rem 0;
    background: var(--white);
  }

  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 2.5rem;
  }

  .section-header h2 {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    color: var(--olive-green);
    margin-bottom: 0.75rem;
    font-weight: 700;
  }

  .section-header p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--black);
    opacity: 0.85;
  }

  .product-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .product-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    border: 2px solid rgba(90,110,69,0.08);
    transition: all 0.3s ease;
    position: relative;
  }

  .product-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    transform: translateY(-4px);
  }

  .product-card.featured {
    box-shadow: 0 4px 20px rgba(84,101,61,0.15);
  }

  .product-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: linear-gradient(135deg, var(--olive-green) 0%, #4a5d38 100%);
    color: var(--white);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 0.875rem;
    border-radius: var(--radius-sm);
    z-index: 2;
    letter-spacing: 0.02em;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .product-card-image {
    width: 100%;
    height: 220px;
    overflow: hidden;
  }

  .product-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .product-card:hover .product-card-image img {
    transform: scale(1.03);
  }

  .product-card-body {
    padding: 1.5rem;
  }

  .product-card-body h3 {
    font-size: 1.5rem;
    color: var(--olive-green);
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .product-card-body > p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--black);
    opacity: 0.85;
